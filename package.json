{
  "name": "@damoqiongqiu/mcp-local-translate",
  "version": "0.1.8",
  "description": "Zero-dependency local translation engine via Transformers.js NLLB model — translate text across 200+ languages, CPU-only, no cloud APIs, everything stays on your machine.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-local-translate": "dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "keywords": [
    "typescript",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "translation",
    "nllb",
    "transformers",
    "huggingface",
    "local-ai",
    "offline",
    "privacy",
    "multilingual",
    "developer-tools",
    "ai-assistant"
  ],
  "author": "Shinsuke Kagawa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/damoqiongqiu/mcp-local-translate.git"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "prepare": "husky"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "franc-min": "^6.2.0",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "mcpName": "io.github.damoqiongqiu/mcp-local-translate",
  "publishConfig": {
    "access": "public"
  }
}
